{
  "manifest_version": 3,
  "name": "DivGrab",
  "version": "1.0",
  "description": "Select any element on a website and extract its HTML, CSS, and JS.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DivGrab"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}